# API
API_ORDERS_URL=https://apisayri.atic.pe/api/orders/ordersales/
Company=10813
ORDER_STATUS=Registrado
API_AUTH_MODE=basic
API_USERNAME=colocar_usuario
API_PASSWORD=colocar_password
API_TOKEN=
API_TOKEN_HEADER=Authorization
API_TOKEN_PREFIX=Bearer
API_TIMEOUT_SECONDS=30
API_VERIFY_TLS=true

# Si la API acepta filtros adicionales en querystring, colocalos como JSON.
# Company y Status se toman de las variables Company y ORDER_STATUS.
# Ejemplo: {"Proceced": false}
API_QUERY_PARAMS_JSON={}

# Headers opcionales adicionales.
# Ejemplo: {"X-Company": "6420"}
API_HEADERS_JSON={}

# Endpoint para marcar el pedido como impreso enviando Details.
# Ajusta la ruta real segun tu API.
# Ejemplo: https://apisayri.atic.pe/api/orders/ordersales/{order_id}/
API_PRINTED_URL_TEMPLATE=https://apisayri.atic.pe/api/orders/ordersales/{order_id}/
API_PRINTED_METHOD=PATCH

# Servicio
POLL_SECONDS=10
IDLE_SLEEP_SECONDS=10
ERROR_SLEEP_SECONDS=30
LOG_BACKUP_COUNT=7

# Impresion
PRINT_COPIES=1
PRINT_ENCODING=cp850
PRINT_CODEPAGE_COMMAND_HEX=1B7402
PRINT_DOCUMENT_TITLE=TicketProduccion
PRINT_FEED_LINES=4
PRINT_CUT_ENABLED=true
# Comando ESC/POS de corte en hexadecimal.
# Comunmente:
# 1D5641   -> GS V A   (corte parcial)
# 1D5600   -> GS V 0   (corte completo)
PRINT_CUT_COMMAND_HEX=1D5641
PRINT_PRE_CUT_FEED_LINES=3
PRINT_AFTER_JOB_SLEEP_MS=300
PRINT_COMBINE_TICKET_AND_CUT=true
PRINT_BEEP_ENABLED=false
# Debe ser el comando hexadecimal soportado por tu impresora.
PRINT_BEEP_COMMAND_HEX=
# before_ticket | after_ticket | before_cut | after_cut
PRINT_BEEP_POSITION=before_cut
# Si sigue en Printed=false en la API, vuelve a imprimir en cada ciclo.
REPRINT_WHEN_NOT_CONFIRMED=false

# Mapa centro de produccion -> nombre exacto de la impresora en Windows
PRINTER_MAP_JSON={"COCINA":"Nombre Impresora Cocina","BARRA":"Nombre Impresora Barra","PARRILLAS":"Nombre Impresora Parrillas"}
